{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/modules/assets", "src/modules/allocations", "src/modules/audits", "src/modules/bookings", "src/modules/maintenance", "src/modules/users", "src/services/cron.service.ts", "src/services/email.service.ts", "src/services/conflictEngine.ts", "src/scripts/**", "src/utils/assetTagGenerator.ts"]
}
