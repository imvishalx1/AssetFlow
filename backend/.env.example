# ── Server ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database (MongoDB Atlas) ────────────────────────────────────────────
# Local dev example:
# MONGODB_URI=mongodb://localhost:27017/assetflow_erp
# Production Atlas example:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/assetflow_erp
MONGODB_URI=mongodb://localhost:27017/assetflow_erp

# ── JWT ─────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_hex_access_secret
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend URL (CORS allowlist) ───────────────────────────────────────
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Asset Flow Domain Configuration ─────────────────────────────────────
ASSET_TAG_PREFIX=AF-
DEFAULT_CURRENCY=USD

# ── Seed Admin (used ONLY by scripts/seedAdmin.ts) ──────────────────────
# IMPORTANT: change SEED_ADMIN_PASSWORD before any real deployment. Do not
# ship a known/guessable administrator password.
SEED_ADMIN_EMAIL=admin@assetflow.com
SEED_ADMIN_PASSWORD=change_this_strong_password_8plus
SEED_ADMIN_NAME=System Admin

# ── Email (Nodemailer - For Overdue Return & Maintenance Alerts) ────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_smtp_api_key
EMAIL_FROM=alerts@assetflow.com

# ── Monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=
