{
  "name": "assetflow",
  "version": "1.0.0",
  "private": true,
  "description": "AssetFlow — Enterprise Asset & Resource Management System",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev -w frontend",
    "build": "npm run build -w frontend",
    "lint": "npm run lint -w frontend",
    "typecheck": "tsc --noEmit -p frontend/tsconfig.json",
    "audit": "npm audit --audit-level=high",
    "seed": "echo 'Use PATCH /users/:id/promote (Admin-only) to promote users'"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
