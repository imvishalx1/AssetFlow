# ── API (legacy — only used when VITE_MOCK_AUTH=false without Firebase) ──
VITE_API_BASE_URL=http://localhost:5000
VITE_ENABLE_REAL_TIME=false

# Set to "true" to run the UI with in-memory mock data (no backend needed)
VITE_MOCK_AUTH=true

# ── Firebase configuration (required only when VITE_MOCK_AUTH=false) ──
# Create a Firebase project, enable Auth + Firestore, then fill these in.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=assetflow-hackathon
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_USE_EMULATOR=true
