rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────────
    // Helper functions
    // ─────────────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'Admin';
    }

    function isAssetManager() {
      return isAuthenticated() && request.auth.token.role == 'Asset Manager';
    }

    function isDepartmentHead() {
      return isAuthenticated() && request.auth.token.role == 'Department Head';
    }

    function isEmployee() {
      return isAuthenticated() && request.auth.token.role == 'Employee';
    }

    function isSameUser(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function userDepartmentId() {
      return request.auth.token.departmentId;
    }

    // ─────────────────────────────────────────────────────────────────────
    // Default: deny everything
    // ─────────────────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // users/{uid}
    // Read: self or Admin. Write: only Cloud Functions (deny all client writes).
    // ─────────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read: if isSameUser(uid) || isAdmin();
      allow create, update, delete: if false; // only Cloud Functions via Admin SDK

      // Users may write their own name/email IF we wanted self-service profile
      // updates — but role/departmentId must never be client-writable.
      // Currently: deny all client writes intentionally.
    }

    // ─────────────────────────────────────────────────────────────────────
    // departments/{id}
    // Read: all authenticated users (departments are small, shared reference).
    // Write: only Cloud Functions.
    // ─────────────────────────────────────────────────────────────────────

    match /departments/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // categories/{id}
    // Read: all authenticated users.
    // Write: only Cloud Functions.
    // ─────────────────────────────────────────────────────────────────────

    match /categories/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // assets/{id}
    // Admin / Asset Manager: full read.
    // Department Head: read only assets in their own department.
    // Employee: read only assets in their own department (limited).
    // Write: only Cloud Functions.
    // ─────────────────────────────────────────────────────────────────────

    match /assets/{id} {
      allow read: if isAdmin()
                  || isAssetManager()
                  || (isDepartmentHead() && resource.data.departmentId == userDepartmentId())
                  || (isEmployee() && resource.data.departmentId == userDepartmentId());
      allow create, update, delete: if false;

      // history subcollection — same read rules as parent asset
      match /history/{eventId} {
        allow read: if isAdmin()
                    || isAssetManager()
                    || (isDepartmentHead() && resource.data.departmentId == userDepartmentId());
        allow create, update, delete: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // allocations/{id}
    // Anyone can read allocations they are involved in (as userId).
    // Admin / Asset Manager: full read.
    // Department Head: read allocations matching their department.
    // Write: only Cloud Functions.
    // ─────────────────────────────────────────────────────────────────────

    match /allocations/{id} {
      allow read: if isAdmin()
                  || isAssetManager()
                  || (isDepartmentHead() && resource.data.departmentId == userDepartmentId())
                  || resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // transfers/{id}
    // Involved parties can read (from/to users).
    // Admin / Asset Manager: full read.
    // Write: only Cloud Functions.
    // ─────────────────────────────────────────────────────────────────────

    match /transfers/{id} {
      allow read: if isAdmin()
                  || isAssetManager()
                  || resource.data.fromUserId == request.auth.uid
                  || resource.data.toUserId == request.auth.uid
                  || resource.data.requestedBy == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // bookings/{id}
    // Involved user can read. Admin / Asset Manager: full read.
    // Write: only Cloud Functions.
    // ─────────────────────────────────────────────────────────────────────

    match /bookings/{id} {
      allow read: if isAdmin()
                  || isAssetManager()
                  || resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // maintenanceRequests/{id}
    // Raised-by user can read. Admin / Asset Manager: full read.
    // Write: only Cloud Functions.
    // ─────────────────────────────────────────────────────────────────────

    match /maintenanceRequests/{id} {
      allow read: if isAdmin()
                  || isAssetManager()
                  || resource.data.raisedBy == request.auth.uid;
      allow create, update, delete: if false;
    }

    // ─────────────────────────────────────────────────────────────────────
    // auditCycles/{id}
    // Admin: full read + create.
    // Asset Manager: can read.
    // No client-side writes to items (handled by Cloud Functions).
    // ─────────────────────────────────────────────────────────────────────

    match /auditCycles/{id} {
      allow read: if isAdmin() || isAssetManager();
      allow create: if isAdmin();
      allow update, delete: if false;

      // checklistItems subcollection — same rules as parent
      match /checklistItems/{assetId} {
        allow read: if isAdmin() || isAssetManager();
        allow create, update, delete: if false;
      }
    }

    // ─────────────────────────────────────────────────────────────────────
    // activityLogs/{id}
    // IMMUTABLE — create only, for all authenticated users (via Cloud Functions).
    // No role, including Admin, may ever update or delete (FR-10.3).
    // ─────────────────────────────────────────────────────────────────────

    match /activityLogs/{id} {
      allow create: if isAuthenticated(); // Cloud Functions calls with a service account
      allow read: if isAdmin() || isAssetManager();
      allow update, delete: if false; // UNCONDITIONAL — FR-10.3
    }
  }
}
